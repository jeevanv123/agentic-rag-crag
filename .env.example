# ============================================================
# Agentic RAG — CRAG + Self-RAG  |  Environment Variables
# Copy this file to .env and fill in your actual API keys.
# ============================================================

# ----------------------------------------------------------
# Required API keys
# ----------------------------------------------------------
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# ----------------------------------------------------------
# Optional: LangSmith tracing (highly recommended)
# ----------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agentic-rag-crag

# ----------------------------------------------------------
# LLM model configuration
# ----------------------------------------------------------
# Graders (fast, cheap — gpt-4o-mini works well)
GRADER_MODEL=gpt-4o-mini
GRADER_TEMPERATURE=0

# Generator (more powerful for answer quality)
GENERATOR_MODEL=gpt-4o
GENERATOR_TEMPERATURE=0

# Query rewriter
REWRITER_MODEL=gpt-4o-mini
REWRITER_TEMPERATURE=0

# ----------------------------------------------------------
# ChromaDB vector store
# ----------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_collection
EMBEDDING_MODEL=text-embedding-3-small

# Number of documents to retrieve per query
RETRIEVAL_K=4

# ----------------------------------------------------------
# Tavily web search
# ----------------------------------------------------------
# Maximum web results returned per search
TAVILY_MAX_RESULTS=3

# ----------------------------------------------------------
# Graph execution limits
# ----------------------------------------------------------
# Max self-correction loops before falling back to web search
MAX_LOOP_STEPS=3

# ----------------------------------------------------------
# Semantic cache
# ----------------------------------------------------------
SEMANTIC_CACHE_ENABLED=true
# Cosine similarity threshold — questions above this are considered duplicates
SEMANTIC_CACHE_THRESHOLD=0.95
# Max cached entries before oldest is evicted (LRU-style)
SEMANTIC_CACHE_MAX_SIZE=128
