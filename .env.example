# ============================================================
# Agentic RAG — CRAG + Self-RAG  |  Environment Variables
# Copy this file to .env and fill in your actual API keys.
# ============================================================

# ----------------------------------------------------------
# Required: Azure OpenAI
# ----------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ----------------------------------------------------------
# Required: Tavily web search
# ----------------------------------------------------------
TAVILY_API_KEY=tvly-...

# ----------------------------------------------------------
# Optional: LangSmith tracing (highly recommended)
# When enabled, every pipeline run is traced end-to-end in
# the LangSmith UI including node-level latencies and LLM calls.
# ----------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agentic-rag-crag

# ----------------------------------------------------------
# LLM deployment names (Azure deployment IDs, not model names)
# ----------------------------------------------------------
# Graders — fast/cheap model works well (e.g. gpt-4o-mini deployment)
GRADER_MODEL=GPT-4O-MINI-US1-GS
GRADER_TEMPERATURE=0

# Generator — more capable model for answer quality
GENERATOR_MODEL=GPT-4O-US1
GENERATOR_TEMPERATURE=0

# Query rewriter
REWRITER_MODEL=GPT-4O-MINI-US1-GS
REWRITER_TEMPERATURE=0

# ----------------------------------------------------------
# Embeddings (Azure deployment ID)
# ----------------------------------------------------------
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ----------------------------------------------------------
# ChromaDB vector store
# ----------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_collection

# Number of documents to retrieve per query
RETRIEVAL_K=4

# ----------------------------------------------------------
# Tavily web search
# ----------------------------------------------------------
# Maximum web results returned per search
TAVILY_MAX_RESULTS=3

# ----------------------------------------------------------
# Graph execution limits
# ----------------------------------------------------------
# Max generation attempts before falling back to web search
MAX_LOOP_STEPS=3

# ----------------------------------------------------------
# Resilience
# ----------------------------------------------------------
# Max retry attempts for a single external API call
MAX_API_RETRIES=3
